@model Mvc.Features.Models.CartSummaryModel


<div class="card p-3 shadow-sm border-primary" style="max-width: 250px;">
    <div class="d-flex justify-content-between align-items-center">
        <strong>🛒 My Cart</strong>
        <span class="badge bg-primary rounded-pill">@Model.TotalItems</span>
    </div>
    
    @if ((bool)ViewData["ShowDetails"]!)
    {
        <hr />
        <div class="d-flex justify-content-between">
            <span class="text-muted">Total:</span>
            <span class="fw-bold text-success">$@Model.TotalPrice</span>
        </div>
        <a href="" class="btn btn-sm btn-outline-primary w-100 mt-2">Go to Checkout</a>
    }
</div>